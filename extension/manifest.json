{
  "manifest_version": 3,
  "name": "Linkman",
  "version": "1.0",
  "description": "AI-assisted bookmark sync and organization.",
  "permissions": [
    "bookmarks",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
